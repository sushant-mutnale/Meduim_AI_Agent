# ═══════════════════════════════════════════════════════
# LLM (OpenRouter) — REQUIRED
# ═══════════════════════════════════════════════════════
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEFAULT_MODEL=mistralai/mistral-7b-instruct:free

# ═══════════════════════════════════════════════════════
# Image Generation — OPTIONAL
# ═══════════════════════════════════════════════════════
IMAGEROUTER_API_KEY=your_imagerouter_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════════════
# Medium (Playwright-based — no API token needed)
# ═══════════════════════════════════════════════════════
MEDIUM_AUTH_JSON_PATH=medium-automation/auth.json

# ═══════════════════════════════════════════════════════
# Database (Supabase PostgreSQL or local)
# ═══════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_automation

# ═══════════════════════════════════════════════════════
# Redis (Upstash or local)
# ═══════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════
# Source API Keys
# ═══════════════════════════════════════════════════════
GITHUB_TOKEN=
NEWSAPI_KEY=your_newsapi_key_here

# ═══════════════════════════════════════════════════════
# App Settings
# ═══════════════════════════════════════════════════════
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
REQUIRE_MANUAL_APPROVAL=True
MIN_CONFIDENCE_SCORE=0.85
