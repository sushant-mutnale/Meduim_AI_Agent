# ═══════════════════════════════════════════════════════
# LLM (OpenRouter) — REQUIRED
# ═══════════════════════════════════════════════════════
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEFAULT_MODEL=google/gemini-2.0-flash-001

# ═══════════════════════════════════════════════════════
# Medium API — REQUIRED for publishing (optional for testing)
# ═══════════════════════════════════════════════════════
MEDIUM_API_TOKEN=your_medium_integration_token_here
MEDIUM_USER_ID=your_medium_user_id_here

# ═══════════════════════════════════════════════════════
# OpenAI — OPTIONAL (only for DALL-E image generation)
# ═══════════════════════════════════════════════════════
OPENAI_API_KEY=your_openai_api_key_here

# ═══════════════════════════════════════════════════════
# Infrastructure — Use defaults for Docker, change for local
# ═══════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:postgres@db:5432/content_automation
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ═══════════════════════════════════════════════════════
# Source API Keys — OPTIONAL but improve data quality
# ═══════════════════════════════════════════════════════
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AgenticContentPlatform/1.0

# ═══════════════════════════════════════════════════════
# App Settings
# ═══════════════════════════════════════════════════════
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
REQUIRE_MANUAL_APPROVAL=True
MIN_CONFIDENCE_SCORE=0.85
