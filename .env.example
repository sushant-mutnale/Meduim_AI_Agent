# External APIs
OPENAI_API_KEY=your_openai_api_key_here
MEDIUM_API_TOKEN=your_medium_integration_token_here
MEDIUM_USER_ID=your_medium_user_id_here

# Redis
REDIS_URL=redis://redis:6379/0

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db:5432/content_automation


# Application Settings
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Worker Settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Approval Requirements
REQUIRE_MANUAL_APPROVAL=True
MIN_CONFIDENCE_SCORE=0.85
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AgenticContentPlatform/1.0
